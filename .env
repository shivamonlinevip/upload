# Choose your LLM provider: "anthropic" or "gemini"
LLM_PROVIDER=gemini

# --- Anthropic (Claude) — used when LLM_PROVIDER=anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-5

# --- Google Gemini — used when LLM_PROVIDER=gemini ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AQ.Ab8RN6JuavrxgRKUauWvAwlo1wJe4__whh1hORmfAiK7YmLfbg
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional overrides
# If true, the News Agent uses live web search (web_search for Claude,
# Google Search grounding for Gemini) instead of relying on model knowledge alone.
ENABLE_WEB_SEARCH=false
MAX_TOKENS=2000
